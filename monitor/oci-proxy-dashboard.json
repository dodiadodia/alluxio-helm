{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Observability for the Alluxio OCI Registry proxy (HttpServerHandler/OciRegistryHandler) and the worker page cache invalidation path (DoraMetaManager). Pairs with the metrics added in commit ee0b955684d.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "panels": [],
      "title": "OCI proxy — request rate & cache tier",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Per-second request rate to the OCI proxy, broken down by cache tier the request was served from. `memory_cache` and `persistent_cache` are hits; `upstream` is a miss that fell through to ACR; `error` is a failed lookup.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "req/s",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 25,
            "gradientMode": "opacity",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {"group": "A", "mode": "normal"}
          },
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "id": 1,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (source) (rate(alluxio_oci_proxy_requests_total{instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{source}}",
          "refId": "A"
        }
      ],
      "title": "Request rate by cache tier",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Cache hit ratio = (memory_cache + persistent_cache) / total. Sustained drops here are the first sign of a churn problem; correlate with the invalidation panels below.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 0.7},
              {"color": "green", "value": 0.9}
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 1},
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(rate(alluxio_oci_proxy_requests_total{instance=~\"$instance\",source=~\"memory_cache|persistent_cache\"}[$__rate_interval])) / clamp_min(sum(rate(alluxio_oci_proxy_requests_total{instance=~\"$instance\"}[$__rate_interval])), 1e-9)",
          "legendFormat": "hit ratio",
          "refId": "A"
        }
      ],
      "title": "Cache hit ratio",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Request rate split by HTTP method (HEAD vs GET). HEAD-heavy traffic is normal during containerd manifest probing; sustained GET dominance against an unchanged image set is suspicious.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "stacking": {"group": "A", "mode": "none"}
          },
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 1},
      "id": 3,
      "options": {
        "legend": {"calcs": ["mean"], "displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (method) (rate(alluxio_oci_proxy_requests_total{instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ],
      "title": "Request rate by HTTP method",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 101,
      "panels": [],
      "title": "OCI proxy — traffic served & upstream load",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Bytes served per second, split by `cache` (served from worker page store, zero ACR egress) vs `upstream` (proxied from ACR, billable egress).",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 25,
            "lineWidth": 1,
            "stacking": {"group": "A", "mode": "normal"}
          },
          "unit": "Bps"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "id": 4,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (source) (rate(alluxio_oci_proxy_bytes_served_bytes_total{instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{source}}",
          "refId": "A"
        }
      ],
      "title": "Bytes served per second",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Upstream fetch rate against ACR (left axis, ops/s) overlaid with upstream throughput (right axis, B/s — bytes streamed from ACR through the worker to the client). Fetches split by `success` (HTTP 2xx/3xx) vs `error` (exception or HTTP >=400). A spike in `error` typically precedes a cache-warming stampede; throughput ÷ ops/s ≈ average upstream blob size.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1
          },
          "unit": "ops"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "upstream throughput"},
            "properties": [
              {"id": "unit", "value": "Bps"},
              {"id": "custom.axisPlacement", "value": "right"},
              {"id": "custom.axisLabel", "value": "B/s"},
              {"id": "color", "value": {"fixedColor": "orange", "mode": "fixed"}},
              {"id": "custom.lineWidth", "value": 2}
            ]
          }
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "id": 5,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (type, result) (rate(alluxio_oci_proxy_upstream_fetches_total{instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{type}} / {{result}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(rate(alluxio_oci_proxy_bytes_served_bytes_total{instance=~\"$instance\",source=\"upstream\"}[$__rate_interval]))",
          "legendFormat": "upstream throughput",
          "refId": "B"
        }
      ],
      "title": "Upstream ACR fetches & throughput",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "id": 102,
      "panels": [],
      "title": "OCI proxy — singleflight & blob cache invalidations",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Per-second role breakdown of `fetchBlobWithSingleflight`. Healthy steady state: leaders ≈ misses, followers >> leaders during cold-start, fallbacks ≈ 0. A non-zero `fallback` rate means a leader exhausted retry attempts and gave up — investigate ACR latency or worker contention.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1
          },
          "unit": "ops"
        },
        "overrides": [
          {
            "matcher": {"id": "byRegexp", "options": ".*fallback.*"},
            "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]
          }
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 19},
      "id": 6,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (type, role) (rate(alluxio_oci_proxy_singleflight_total{instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{type}} / {{role}}",
          "refId": "A"
        }
      ],
      "title": "Singleflight role mix",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Per-second blob-level invalidations triggered by OciRegistryHandler, labeled by the code path that triggered the drop:\n• `length_mismatch` / `digest_mismatch` — cached object's length or digest no longer agrees with the upstream metadata.\n• `stream_aborted` — fetch from ACR failed mid-stream while writing into the page store.\n• `page0_absent` — first page missing on a HEAD-like probe.\n• `page_missing_mid_stream` — a page disappeared between two reads (eviction or external delete).\n• `cached_stream_aborted` — reader's stream broke during a cache replay.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 25,
            "lineWidth": 1,
            "stacking": {"group": "A", "mode": "normal"}
          },
          "unit": "ops"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 19},
      "id": 7,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (reason) (rate(alluxio_oci_proxy_cache_invalidations_total{instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "title": "Blob cache invalidations by reason",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 27},
      "id": 103,
      "panels": [],
      "title": "Worker page cache — invalidations (DoraMetaManager)",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Per-second page cache invalidations driven by metadata refresh, labeled by reason. Use this to triage dashboard page-count drops:\n• `hash_mismatch` — content hash diverged between origin and refreshed metadata (legitimate UFS change).\n• `length_changed` — file length changed (legitimate UFS change).\n• `ufs_type_changed` / `file_type_changed` — pathological mount or symlink flip.\n• `origin_hash_null` / `updated_hash_null` — conservative drop because one side has no content hash; this is the trap that produced the Grafana drop incident.\n• `metadata_removed` — entry deleted from the meta cache.\n• `unspecified` — legacy call site without a labeled reason.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 25,
            "lineWidth": 1,
            "stacking": {"group": "A", "mode": "normal"}
          },
          "unit": "ops"
        },
        "overrides": [
          {
            "matcher": {"id": "byRegexp", "options": ".*hash_null.*"},
            "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]
          }
        ]
      },
      "gridPos": {"h": 9, "w": 16, "x": 0, "y": 28},
      "id": 8,
      "options": {
        "legend": {"calcs": ["mean", "max", "sum"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (reason) (rate(alluxio_page_cache_invalidations_total{instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "title": "Page cache invalidations by reason (rate)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Total invalidations attributed to each reason over the dashboard time range. Useful to pick the dominant cause after a drop event.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"hideFrom": {"legend": false, "tooltip": false, "viz": false}},
          "unit": "short"
        }
      },
      "gridPos": {"h": 9, "w": 8, "x": 16, "y": 28},
      "id": 9,
      "options": {
        "displayLabels": ["name", "percent"],
        "legend": {"displayMode": "table", "placement": "right", "showLegend": true, "values": ["value"]},
        "pieType": "donut",
        "reduceOptions": {"calcs": ["sum"], "fields": "", "values": false},
        "tooltip": {"mode": "single", "sort": "none"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (reason) (increase(alluxio_page_cache_invalidations_total{instance=~\"$instance\"}[$__range]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "title": "Invalidation reason mix (selected range)",
      "type": "piechart"
    }
  ],
